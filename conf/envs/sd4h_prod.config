/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal to SD4H Prod environment
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines required url to various endpoint and services
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'SD4H Prod profile'
    config_profile_description = 'SD4H Prod Prod profile to check pipeline function'

    // data staging params
    file_manager_url             = "https://file-manager.submission.genomelibrary.ca"
    file_transfer_url            = "https://file-transfer.submission.genomelibrary.ca"
    file_manager_url_upload      = "https://file-manager.submission.genomelibrary.ca"
    file_transfer_url_upload     = "https://file-transfer.submission.genomelibrary.ca"
    clinical_url      = "https://submission.genomelibrary.ca"
}